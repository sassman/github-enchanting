{
  "manifest_version": 3,
  "name": "Github Enchanting",
  "version": "1.1.0",
  "description": "Adds a tools like Dependabot command dropdown PRs on GitHub",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*/pull/*"],
      "js": ["shared.js", "content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://github.com/*/*/pulls", "https://github.com/*/*/pulls?*"],
      "js": ["shared.js", "list.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ]
}
